		lineageTag: 649147cb-3d63-4523-9d1c-a2c6f2c2ba53
		summarizeBy: sum
		sourceColumn: accuracy

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// A statistical score between 0 and 1 measuring how well the model distinguishes between invoices that will and will not become overdue; closer to 1 means better performance.
	column auc_roc
		dataType: double
		lineageTag: d4b36f74-71fd-4b34-83a9-23c842481191
		summarizeBy: sum
		sourceColumn: auc_roc

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

