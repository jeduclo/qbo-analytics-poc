	/// The name identifying which machine learning model this performance record describes, such as the invoice overdue-risk classifier.
	column model_name
		dataType: string
		lineageTag: 11018f43-2d44-46c0-a104-446a36df5249
		summarizeBy: none
		sourceColumn: model_name

		annotation SummarizationSetBy = Automatic

