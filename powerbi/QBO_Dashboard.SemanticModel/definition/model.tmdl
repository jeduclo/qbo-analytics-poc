model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-CA
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["qbo ml_invoice_predictions","qbo ml_model_metadata","qbo ml_revenue_forecast","qbo vw_ar_aging","qbo vw_bs_structure","qbo vw_cash_received","qbo vw_invoice_detail","qbo vw_pl_structure","qbo vw_sales_summary"]

annotation PBI_ProTooling = ["MCP-PBIModeling","DevMode"]

ref table 'qbo ml_invoice_predictions'
ref table 'qbo ml_model_metadata'
ref table 'qbo ml_revenue_forecast'
ref table 'qbo vw_ar_aging'
ref table 'qbo vw_bs_structure'
ref table 'qbo vw_cash_received'
ref table 'qbo vw_invoice_detail'
ref table 'qbo vw_pl_structure'
ref table 'qbo vw_sales_summary'
ref table Date
ref table _Measures

ref cultureInfo en-US

